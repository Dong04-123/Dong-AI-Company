# =============================================================================
# Dong AI 环境变量（复制为 .env 使用）
# =============================================================================
# 复制此文件: cp .env.example .env

# --- API 认证 ---
# 设置后 API 需要 Bearer token 才能访问
DONG_API_KEY=your-api-key-here

# 多租户：多个 API Key 映射到不同租户（JSON 格式）
# DONG_API_KEYS={"sk-tenant1-key":"tenant1","sk-tenant2-key":"tenant2"}

# Webhook 认证
DONG_WEBHOOK_TOKEN=your-webhook-secret

# --- AI Provider ---
# DeepSeek API
DEEPSEEK_API_KEY=sk-your-deepseek-key

# OpenAI API
# OPENAI_API_KEY=sk-your-openai-key

# 其他可选 Provider（取消注释使用）
# ANTHROPIC_API_KEY=...
# OPENROUTER_API_KEY=...
# GOOGLE_API_KEY=...
# GROQ_API_KEY=...
# KIMI_API_KEY=...
