{
  "name": "@dong-ai/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the Dong AI Company API — OpenAI-compatible endpoints with retry, rate-limit handling, typed errors, and React hooks. Gets better with every project.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    },
    "./react": {
      "import": {
        "types": "./dist/react.d.ts",
        "default": "./dist/react.js"
      },
      "require": {
        "types": "./dist/cjs/react.d.ts",
        "default": "./dist/cjs/react.js"
      }
    }
  },
  "bin": {
    "dongai": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.cjs.json && node scripts/postbuild.mjs",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build && npm test",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "preversion": "npm test",
    "version": "npm run build",
    "postversion": "git push && git push --tags"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "react": "^18.0 || ^19.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.17",
    "react": "^19.2.7",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "dong-ai",
    "ai-company",
    "agent",
    "multi-agent",
    "openai-compatible",
    "sdk",
    "typescript",
    "react"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Dong04-123/Dong-AI-Company"
  },
  "homepage": "https://github.com/Dong04-123/Dong-AI-Company",
  "bugs": {
    "url": "https://github.com/Dong04-123/Dong-AI-Company/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
